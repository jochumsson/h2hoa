@prefix h2ho:    <https://w3id.org/jochumsson/h2ho#> .
@prefix ho61508: <https://w3id.org/jochumsson/ho61508#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

#################################################################
# H2HO DOMAIN RESTRICTIONS (CAUSAL RELATIONS)
#################################################################
#
# This file contains domain-level causal and manifestation rules 
# for hydrogen hazard analysis. These rules are NOT part of
# the conceptual H2HO ontology described in the paper "A Hazard 
# Ontology Based on IEC 61508", but are added at later state during
# knowledge base construction, discussed in the paper: "Towards 
# Ontological Semantics for Hazard Analysis with Automatic Reasoning".
#
# These rules, belong to the application layer: scenario 
# modelling, causal sequence construction, and hazard analysis.
#
# They illustrate how HO61508 object properties (resultsIn, 
# enables, manifestsIn) may be used to express domain physics. 
#
# The conceptual ontology (h2ho.ttl) intentionally excludes such
# rules to remain general, reusable, and structurally aligned 
# with IEC 61508.
#
#################################################################

#################################################################
# Hazard inherence restrictions
#################################################################

### FlammabilityHazard inherits in hydrogen system elements
h2ho:FlammabilityHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Flammability hazards originate from any component capable of releasing combustible hydrogen mixtures, including equipment, storage, piping, and confined environments." ;
    owl:onProperty ho61508:inheresIn ;
    owl:someValuesFrom [
        owl:unionOf (
            h2ho:StorageVesselHazardSource
            h2ho:PipingHazardSource
            h2ho:ProcessEquipmentHazardSource
            h2ho:EnvironmentalConfinementHazardSource
        )
    ]
] .


### OxygenDeficiencyHazard inherits in confined environments
h2ho:OxygenDeficiencyHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Oxygen deficiency hazards occur only in confined environments where displacement of breathable air may occur." ;
    owl:onProperty ho61508:inheresIn ;
    owl:someValuesFrom h2ho:EnvironmentalConfinementHazardSource
] .


### ThermalHazard inherits in equipment or storage
h2ho:ThermalHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Thermal hazards arise from hot or cryogenic surfaces, venting, or thermal effects from equipment, piping, or storage." ;
    owl:onProperty ho61508:inheresIn ;
    owl:someValuesFrom [
        owl:unionOf (
            h2ho:StorageVesselHazardSource
            h2ho:PipingHazardSource
            h2ho:ProcessEquipmentHazardSource
        )
    ]
] .


### PressureHazard inherits in pressurised hardware or confined volumes
h2ho:PressureHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Pressure hazards may originate from storage vessels, piping systems, or confined environments where pressure buildup may occur." ;
    owl:onProperty ho61508:inheresIn ;
    owl:someValuesFrom [
        owl:unionOf (
            h2ho:StorageVesselHazardSource
            h2ho:PipingHazardSource
            h2ho:EnvironmentalConfinementHazardSource
        )
    ]
] .


### ElectricalPowerHazard inherits in process equipment
h2ho:ElectricalPowerHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Electrical power hazards are associated with equipment that utilizes or converts electricity, including electrolysers and fuel cells." ;
    owl:onProperty ho61508:inheresIn ;
    owl:someValuesFrom h2ho:ProcessEquipmentHazardSource
] .


### ToxicityHazard inherits in storage, process equipment, or confined volumes
h2ho:ToxicityHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Toxicity-related hazards (including cryogenic exposure effects) may arise from storage systems, piping, process equipment, or confined spaces where harmful atmospheres may accumulate." ;
    owl:onProperty ho61508:inheresIn ;
    owl:someValuesFrom [
        owl:unionOf (
            h2ho:StorageVesselHazardSource
            h2ho:PipingHazardSource
            h2ho:ProcessEquipmentHazardSource
            h2ho:EnvironmentalConfinementHazardSource
        )
    ]
] .


#################################################################
# HazardSource inherence restrictions
#################################################################

### StorageVesselHazardSource must be played by a StorageVessel
h2ho:StorageVesselHazardSource rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Instances of StorageVesselHazardSource are played by StorageVessel endurants." ;
    owl:onProperty ho61508:carriedBy ;
    owl:someValuesFrom h2ho:StorageVessel
] .

### PipingHazardSource must be played by a Piping endurant
h2ho:PipingHazardSource rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Instances of PipingHazardSource are played by Piping endurants." ;
    owl:onProperty ho61508:carriedBy ;
    owl:someValuesFrom h2ho:Piping
] .

### ProcessEquipmentHazardSource must be played by ProcessEquipment
h2ho:ProcessEquipmentHazardSource rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Instances of ProcessEquipmentHazardSource are played by ProcessEquipment endurants." ;
    owl:onProperty ho61508:carriedBy ;
    owl:someValuesFrom h2ho:ProcessEquipment
] .

### EnvironmentalConfinementHazardSource must be played by EnvironmentalConfinement
h2ho:EnvironmentalConfinementHazardSource rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Instances of EnvironmentalConfinementHazardSource are played by EnvironmentalConfinement endurants." ;
    owl:onProperty ho61508:carriedBy ;
    owl:someValuesFrom h2ho:EnvironmentalConfinement
] .

#################################################################
# Fundamental hydrogen combustion chain
#################################################################

### HydrogenRelease → FlammableCondition
h2ho:HydrogenRelease rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A HydrogenRelease produces a flammable hydrogen-air condition through dispersion and mixing, replacing the former ExplosiveAtmosphere notion." ;
    owl:onProperty ho61508:resultsIn ;
    owl:someValuesFrom h2ho:FlammableCondition
] .

### FlammableCondition → Ignition
h2ho:FlammableCondition rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A flammable hydrogen-air condition enables Ignition when an ignition source interacts with the mixture, starting the combustion chain." ;
    owl:onProperty ho61508:enables ;
    owl:someValuesFrom h2ho:Ignition
] .

h2ho:DetonationCondition rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "This situation kan enables flame acceleration due to turbulence-enhanced combustion." ;
    owl:onProperty ho61508:enables ;
    owl:someValuesFrom h2ho:FlameAcceleration
] .

h2ho:FlameAcceleration rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "Flame acceleration triggers the detonation hazard by increasing flame speed and shock formation." ;
    owl:onProperty ho61508:triggers ;
    owl:someValuesFrom h2ho:DetonationHazard
] .

#################################################################
# Hazard manifestation rules 
#################################################################

### FlammabilityHazard manifests in either Fire or Explosion
h2ho:FlammabilityHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A FlammabilityHazard may manifest as either a Fire or an Explosion, depending on mixture geometry, ignition conditions, and confinement." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom [
        owl:unionOf (
            h2ho:Fire
            h2ho:Explosion
        )
    ]
] .

### JetFireHazard manifests as JetFire
h2ho:JetFireHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A JetFireHazard manifests as a high-momentum ignited release of hydrogen." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:JetFire
] .

### FireballHazard manifests as Fireball
h2ho:FireballHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A FireballHazard manifests when a flammable cloud ignites in an unconfined or semi-confined volume." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:Fireball
] .

### PoolFireHazard manifests as PoolFire
h2ho:PoolFireHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A PoolFireHazard manifests when evaporating liquid hydrogen or cryogenic spill ignites as a burning pool." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:PoolFire
] .

### DeflagrationHazard manifests as Deflagration
h2ho:DeflagrationHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A DeflagrationHazard manifests as a subsonic flame propagation event." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:Deflagration
] .

### DetonationHazard manifests as Detonation
h2ho:DetonationHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A DetonationHazard manifests as a supersonic combustion event in a hydrogen–air mixture." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:Detonation
] .

### PressureHazard manifests in high-pressure exposure
h2ho:PressureHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A PressureHazard manifests as a harmful high-pressure exposure event affecting persons or structures." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:HighPressureExposureEvent
] .

### OxygenDeficiencyHazard manifests as oxygen deficiency exposure
h2ho:OxygenDeficiencyHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "An OxygenDeficiencyHazard manifests as an exposure event in which persons are subjected to a low-oxygen atmosphere." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:OxygenDeficiencyExposureEvent
] .

### ToxicityHazard manifests as toxic exposure
h2ho:ToxicityHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A ToxicityHazard manifests as a harmful exposure event involving toxic or harmful substances, including cryogenic media or chemical byproducts." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:ToxicExposureEvent
] .

### ElectricalPowerHazard manifests as electrical shock
h2ho:ElectricalPowerHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "An ElectricalPowerHazard manifests as an electrical shock harmful event." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:ElectricalShock
] .

### ThermalHazard manifests as thermal exposure
h2ho:ThermalHazard rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment "A ThermalHazard manifests as a thermal exposure harmful event, representing injury or damage due to hot or cryogenic thermal conditions." ;
    owl:onProperty ho61508:manifestsIn ;
    owl:someValuesFrom h2ho:ThermalExposureEvent
] .


#################################################################
# HarmfulEvent leadsTo HazardousSituation restrictions
#################################################################

h2ho:Deflagration rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:leadsTo ;
    owl:allValuesFrom [
        owl:unionOf (
            h2ho:DetonationCondition
            h2ho:ExposureSituation
            h2ho:DamagedEquipmentDegradation
        )
    ]
] .


#################################################################
# Cryogenic degradation chain (most common LH2 causal pattern)
#################################################################

### CryogenicMaterialDegradation → Rupture
h2ho:CryogenicMaterialDegradation rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:enables ;
    owl:someValuesFrom h2ho:Rupture
] .


