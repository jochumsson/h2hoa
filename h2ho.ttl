@prefix h2ho:    <https://w3id.org/jochumsson/h2ho#> .
@prefix ho61508: <https://w3id.org/jochumsson/ho61508#> .
@prefix gufo:    <https://purl.org/nemo/gufo#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .

<https://w3id.org/jochumsson/h2ho>
    rdf:type owl:Ontology ;
    owl:imports <https://w3id.org/jochumsson/ho61508> ;
    owl:imports <https://purl.org/nemo/gufo> ;
    rdfs:comment """Hydrogen Safety Ontology (H2HO).
A domain-specific extension of HO61508 following the modular structure
described in 'A Modular Hazard Ontology Based on IEC 61508'.""" .


#################################################################
# H2HO ho61508:HazardSource specialisations
#################################################################

h2ho:StorageVessel rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardSource ;
    rdfs:comment "Component or system whose main function is to store hydrogen or related media (gas or liquid)." .

h2ho:LH2Storage rdf:type owl:Class ;
    rdfs:subClassOf h2ho:StorageVessel ;
    rdfs:comment "Cryogenic tank or containment system storing liquid hydrogen (LH2)." .

h2ho:HighPressureH2Storage rdf:type owl:Class ;
    rdfs:subClassOf h2ho:StorageVessel ;
    rdfs:comment "Storage vessel containing hydrogen at elevated pressure." .

h2ho:Piping rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardSource ;
    rdfs:comment "Piping or pipework used to transport hydrogen between system components." .

h2ho:ProcessEquipment rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardSource ;
    rdfs:comment "Equipment that processes, conditions, or uses hydrogen (for example compressors, valves, reformers, fuel cells)." .

h2ho:Valve rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ProcessEquipment ;
    rdfs:comment "A flow-control component within hydrogen systems. Valves may jam or malfunction under cryogenic conditions, enabling LossOfFunction events such as ValveJam." .

h2ho:Electrolyser rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ProcessEquipment ;
    rdfs:comment "Equipment that produces hydrogen through electrolysis. Can play the role ho61508:HazardSource when participating in accident scenarios." .

h2ho:FuelCell rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ProcessEquipment ;
    rdfs:comment "Equipment that converts hydrogen into electricity. Can play the role ho61508:HazardSource when participating in accident scenarios." .


h2ho:EnvironmentalConfinement rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardSource ;
    rdfs:comment "Structures or surroundings that confine hydrogen or combustion products, such as buildings, enclosures, or congested layouts." .

#################################################################
# H2HO ho61508:Hazard specialisations
#################################################################

h2ho:FlammabilityHazard rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Hazard ;
    rdfs:comment "Disposition for hydrogen mixtures or systems to undergo combustion phenomena (jet fire, fireball, deflagration, detonation)." .

h2ho:JetFireHazard rdf:type owl:Class ;
    rdfs:subClassOf h2ho:FlammabilityHazard ;
    rdfs:comment "Hazard whose manifestation is a jet fire." .

h2ho:FireballHazard rdf:type owl:Class ;
    rdfs:subClassOf h2ho:FlammabilityHazard ;
    rdfs:comment "Hazard whose manifestation is a fireball." .

h2ho:PoolFireHazard rdf:type owl:Class ;
    rdfs:subClassOf h2ho:FlammabilityHazard ;
    rdfs:comment "Hazard whose manifestation is a pool fire." .

h2ho:DeflagrationHazard rdf:type owl:Class ;
    rdfs:subClassOf h2ho:FlammabilityHazard ;
    rdfs:comment "Hazard whose manifestation is a deflagration (slow or fast)." .

h2ho:DetonationHazard rdf:type owl:Class ;
    rdfs:subClassOf h2ho:FlammabilityHazard ;
    rdfs:comment "Hazard whose manifestation is a detonation." .

h2ho:OxygenDeficiencyHazard rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Hazard ;
    rdfs:comment "Disposition for an atmosphere to become oxygen deficient, for example by displacement with hydrogen, leading to asphyxiation risk." .

h2ho:ThermalHazard rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Hazard ;
    rdfs:comment "Disposition to cause harmful thermal exposure (heat flux, high temperature) to people or structures." .

h2ho:PressureHazard rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Hazard ;
    rdfs:comment "Disposition to cause harmful overpressure or pressure waves, for example from explosions or detonations." .

h2ho:ElectricalPowerHazard rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Hazard ;
    rdfs:comment "Disposition associated with electrical power that may result in electrical shock, arcing, or ignition of hydrogen." .

h2ho:ToxicityHazard rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Hazard ;
    rdfs:comment "Disposition to cause harm through exposure to toxic substances, such as ammonia in hydrogen energy systems." .


#################################################################
# H2HO ho61508:HazardousEvent specialisations
#################################################################

h2ho:Malfunction rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousEvent ;
    rdfs:comment "HazardousEvent where a system or component performs an unintended or unsafe function while still operating (e.g., electrolyser or fuel cell mixing hydrogen with oxygen). Distinguished from LossOfFunction, which represents absence of intended functionality." .

h2ho:LossOfFunction rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousEvent ;
    rdfs:comment "Deviation from required functional capability. First abstraction level in the modular IEC 61508 event structure." .

h2ho:LossOfContainment rdf:type owl:Class ;
    rdfs:subClassOf h2ho:LossOfFunction ;
    rdfs:comment "Loss of physical containment of hydrogen. A specialisation of LossOfFunction." .

h2ho:PipePlug rdf:type owl:Class ;
    rdfs:subClassOf h2ho:LossOfFunction ,
        [ rdf:type owl:Restriction ;
          owl:onProperty ho61508:enables ;
          owl:someValuesFrom h2ho:LossOfContainment
        ] ;
    rdfs:comment "A LossOfFunction event in which pipes or orifices become blocked due to the solidification of atmospheric gases (e.g., air or nitrogen) when exposed to liquid hydrogen temperatures. This blockage may enable or contribute to a subsequent LossOfContainment event." .

h2ho:ValveJam rdf:type owl:Class ;
    rdfs:subClassOf h2ho:LossOfFunction ,
        [ rdf:type owl:Restriction ;
          owl:onProperty ho61508:enables ;
          owl:someValuesFrom h2ho:LossOfContainment
        ] ;
    rdfs:comment "A LossOfFunction event in which a valve becomes stuck or jammed due to cryogenic freezing of atmospheric gases or condensate. The loss of valve operability may enable or contribute to a subsequent LossOfContainment event." .

h2ho:AirLeakage rdf:type owl:Class ;
    rdfs:subClassOf h2ho:LossOfFunction ,
        [ rdf:type owl:Restriction ;
          owl:onProperty ho61508:enables ;
          owl:someValuesFrom h2ho:CryogenicMaterialDegradation
        ] ;
    rdfs:comment "LossOfFunction event where air, nitrogen, or other ambient gases leak into liquid hydrogen equipment, enabling freezing, oxygen enrichment, cryopumping and subsequent degradation." .

h2ho:HydrogenRelease rdf:type owl:Class ;
    rdfs:subClassOf h2ho:LossOfContainment ;
    rdfs:comment "Uncontrolled hydrogen release following containment failure." .

h2ho:HighPressureRelease rdf:type owl:Class ;
    rdfs:subClassOf h2ho:HydrogenRelease ;
    rdfs:comment "Hydrogen release from a high pressure vessel or piping." .

h2ho:Rupture rdf:type owl:Class ;
    rdfs:subClassOf h2ho:HighPressureRelease ;
    rdfs:comment "Sudden or catastrophic failure of containment (rupture), typically initiating a rapid hydrogen release." .

h2ho:LowPressureRelease rdf:type owl:Class ;
    rdfs:subClassOf h2ho:HydrogenRelease ;
    rdfs:comment "Hydrogen release from a low pressure source." .

h2ho:LH2Release rdf:type owl:Class ;
    rdfs:subClassOf h2ho:HydrogenRelease ;
    rdfs:comment "Release of liquid hydrogen (LH2), potentially forming cryogenic and flammable hazards." .

h2ho:Ignition rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousEvent ;
    rdfs:comment "Ignition of a hydrogen-air mixture." .

h2ho:FlameIgnition rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Ignition ;
    rdfs:comment "Ignition caused by an open flame (e.g., burner flame, torch, flare, welding flame)." .

h2ho:HotSurfaceIgnition rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Ignition ;
    rdfs:comment "Ignition caused by a sufficiently hot surface in contact with a hydrogen–air mixture." .

h2ho:FrictionIgnition rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Ignition ;
    rdfs:comment "Ignition caused by friction heating between components (bearings, misaligned parts, worn equipment)." .

h2ho:StaticSparkIgnition rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Ignition ;
    rdfs:comment "Ignition caused by electrostatic discharge (ESD), even below human perception threshold." .


h2ho:ExternalEvent rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousEvent ;
    rdfs:comment "Hazardous event external to the hydrogen system (for example impact, earthquake, lightning) that may initiate or escalate an accident scenario." .

h2ho:FlameAcceleration rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousEvent ;
    rdfs:comment "Intermediate event where flame speed increases due to confinement, congestion, or turbulence." .

#################################################################
# H2HO ho61508:HazardousSituation specialisations
#################################################################

h2ho:ExplosiveAtmosphere rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousSituation ;
    rdfs:comment "Hazardous situation where a hydrogen-air mixture is within flammability limits." .

h2ho:TurbulentMixture rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ExplosiveAtmosphere ;
    rdfs:comment "HazardousSituation in which a hydrogen–air mixture is within flammability limits and exhibits turbulence. Turbulence promotes flame instability and flame acceleration, enabling the DDT process." .

h2ho:ExposureSituation rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousSituation ;
    rdfs:comment "Hazardous situation in which exposed entities are subject to harmful energy or substances (thermal, cryogenic, toxic)." .

h2ho:LiquidHydrogenExposure rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ExposureSituation ;
    rdfs:comment "Hazardous situation in which substances or components are directly exposed to liquid hydrogen, enabling freezing, solidification, and subsequent material degradation." .

h2ho:Contamination rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousSituation ;
    rdfs:comment "Hazardous situation in which hydrogen or related substances contaminate an area, medium, or equipment." .
	
h2ho:OxygenEnrichment rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Contamination ;
    rdfs:comment "Cryogenic contamination scenario leading to oxygen-enriched liquid air." .

h2ho:Overpressure rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousSituation ;
    rdfs:comment "Hazardous situation characterised by elevated pressure levels that may threaten structures or people." .

h2ho:MaterialDegradation rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HazardousSituation ;
    rdfs:comment "Hazardous situation in which materials or components have degraded (for example due to hydrogen embrittlement) increasing the likelihood of failure." .

h2ho:CryogenicMaterialDegradation rdf:type owl:Class ;
    rdfs:subClassOf h2ho:MaterialDegradation ,
        [ rdf:type owl:Restriction ;
          owl:onProperty ho61508:enables ;
          owl:someValuesFrom h2ho:LossOfFunction
        ] ;
    rdfs:comment "HazardousSituation in which materials, components, or equipment experience degradation due to cryogenic conditions. Examples include freezing of atmospheric gases (air, nitrogen) into solid deposits, loss of ductility, brittleness, and condensate accumulation. CryogenicMaterialDegradation increases the likelihood of LossOfFunction events such as PipePlug, ValveJam, or Cryopumping, and may ultimately enable LossOfContainment or Rupture during warm-up or pressure rise. This situation corresponds to the mechanisms described in ISO 15916 §6.2.3: solidification of gases, cryopumping vacuum effects, freezing-induced blockages, and oxygen-enriched condensate formation on cold surfaces." .


#################################################################
# H2HO ho61508:Exposed specialisation
#################################################################


h2ho:Person rdf:type owl:Class ;
    rdfs:subClassOf gufo:Endurant ;
    rdfs:comment "A human being who may play the role of Exposed in a HazardousSituation." .

h2ho:Property rdf:type owl:Class ;
    rdfs:subClassOf gufo:Endurant ;
    rdfs:comment "A physical object or structure that may play the role of Exposed in a HazardousSituation." .



#################################################################
# H2HO ho61508:HarmfulEvent specialisations
#################################################################

h2ho:Combustion rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HarmfulEvent ;
    rdfs:comment "Generic harmful combustion event involving hydrogen. Has two primary modes: Fire (non-premixed) and Explosion (premixed)." .

h2ho:Fire rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Combustion ;
    rdfs:comment "Non-premixed combustion where hydrogen burns immediately at the release point. Includes jet fires, pool fires, and fireballs." .

h2ho:JetFire rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Fire ;
    rdfs:comment "Directional flame caused by ignition of a high-velocity hydrogen jet." .

h2ho:PoolFire rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Fire ;
    rdfs:comment "Fire burning on a released pool of liquid hydrogen." .

h2ho:Fireball rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Fire ;
    rdfs:comment "Spherical flame cloud resulting from delayed ignition of a dispersed hydrogen-air mixture." .

h2ho:Explosion rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Combustion ;
    rdfs:comment "Premixed combustion event occurring within a hydrogen-air mixture. Includes deflagrations and detonations." .

h2ho:Deflagration rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Explosion ;
    rdfs:comment "Subsonic premixed combustion wave in hydrogen-air mixtures." .

h2ho:SlowDeflagration rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Deflagration ;
    rdfs:comment "Deflagration with limited flame acceleration." .

h2ho:FastDeflagration rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Deflagration ;
    rdfs:comment "Accelerated deflagration that may transition to detonation (DDT)." .

h2ho:Detonation rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Explosion ;
    rdfs:comment "Supersonic premixed combustion characterized by a shock-induced explosion wave." .

h2ho:PressureWave rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HarmfulEvent ;
    rdfs:comment "Harmful event in which a person or property is affected by a pressure wave, caused by combustion phenomena (deflagration, detonation) or by non-combustion sources." .

h2ho:ElectricalShock rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HarmfulEvent ;
    rdfs:comment "Harmful event in which a person is subjected to electric current or electrical discharge." .

h2ho:ExposureEvent rdf:type owl:Class ;
    rdfs:subClassOf ho61508:HarmfulEvent ;
    rdfs:comment "Harmful event where an entity is exposed to hazardous energy or substances (thermal, cryogenic, toxic)." .

h2ho:HeatExposureEvent rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ExposureEvent ;
    rdfs:comment "Exposure to high temperature or thermal radiation." .

h2ho:CryogenicExposureEvent rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ExposureEvent ;
    rdfs:comment "Exposure to cryogenic temperatures, producing frostbite or cold burns." .

h2ho:ToxicExposureEvent rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ExposureEvent ;
    rdfs:comment "Exposure to a toxic substance producing harm." .

h2ho:AmmoniaExposureEvent rdf:type owl:Class ;
    rdfs:subClassOf h2ho:ToxicExposureEvent ;
    rdfs:comment "Exposure to ammonia (NH3), for example due to leakage from cracking systems or storage." .

#################################################################
# H2HO ho61508:Harm specialisations
#################################################################

h2ho:Damage rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Harm ;
    rdfs:comment "Damage to property or the environment." .

h2ho:Injury rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Harm ;
    rdfs:comment "Non fatal harm to a person." .

h2ho:CryoBurn rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Injury ;
    rdfs:comment "Cold injury to a person caused by cryogenic exposure." .

h2ho:Asphyxiation rdf:type owl:Class ;
    rdfs:subClassOf h2ho:Injury ;
    rdfs:comment "Non fatal oxygen deprivation due to displacement of air by hydrogen or other gases." .

h2ho:Death rdf:type owl:Class ;
    rdfs:subClassOf ho61508:Harm ;
    rdfs:comment "Fatal harm (loss of life)." .


#################################################################
# H2HO Restrictions (causal and manifestation links)
#################################################################

# Hydrogen release results in an explosive atmosphere
h2ho:HydrogenRelease rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:resultsIn ;
    owl:someValuesFrom h2ho:ExplosiveAtmosphere
] .

# Explosive atmosphere enables ignition
h2ho:ExplosiveAtmosphere rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:enables ;
    owl:someValuesFrom h2ho:Ignition
] .

# Hazards manifest in harmful events
h2ho:JetFireHazard rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty ho61508:manifestsIn ;
  owl:someValuesFrom h2ho:JetFire
] .

h2ho:FireballHazard rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty ho61508:manifestsIn ;
  owl:someValuesFrom h2ho:Fireball
] .

h2ho:PoolFireHazard rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty ho61508:manifestsIn ;
  owl:someValuesFrom h2ho:PoolFire
] .

h2ho:DeflagrationHazard rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty ho61508:manifestsIn ;
  owl:someValuesFrom h2ho:Deflagration
] .

h2ho:DetonationHazard rdfs:subClassOf [
  a owl:Restriction ;
  owl:onProperty ho61508:manifestsIn ;
  owl:someValuesFrom h2ho:Detonation
] .

h2ho:CryogenicMaterialDegradation rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:enables ;
    owl:someValuesFrom h2ho:Rupture
] .
