PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ho61508: <https://w3id.org/jochumsson/ho61508#>

SELECT ?harmfulEvent ?harm
WHERE {
  ?harmfulEvent ho61508:causes ?harm .

  ?harmfulEvent rdf:type/rdfs:subClassOf* ho61508:HarmfulEvent .
  ?harm rdf:type/rdfs:subClassOf* ho61508:Harm .
}