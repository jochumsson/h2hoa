@prefix h2hoa:   <https://w3id.org/jochumsson/h2hoa#> .
@prefix h2ho:    <https://w3id.org/jochumsson/h2ho#> .
@prefix ho61508: <https://w3id.org/jochumsson/ho61508#> .
@prefix gufo:    <https://purl.org/nemo/gufo#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://w3id.org/jochumsson/h2hoa>
  a owl:Ontology ;
  dcterms:title "Hydrogen Hazard Analysis Application Ontology (H2HOA)"@en ;
  rdfs:comment "Hydrogen Hazard Analysis Application Ontology (H2HOA). An application extension of H2HO for representing hydrogen hazard analysis."@en ;
  dcterms:creator "Thorvaldur Jochumsson" ;
  dcterms:contributor "Kaj Hänninen" ;
  dcterms:contributor "Mehrdad Saadatmand" ;
  dcterms:contributor "Kristina Lundqvist" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  rdfs:seeAlso <https://github.com/jochumsson/ho61508> ;
  rdfs:seeAlso <https://github.com/jochumsson/h2ho> ;
  dcterms:source "ISO 15916:2015 - Basic considerations for the safety of hydrogen systems."@en ;
  owl:imports <https://w3id.org/jochumsson/ho61508> ;
  owl:imports <https://w3id.org/jochumsson/h2ho> ;
  owl:versionInfo "1.0.0" ;
  owl:versionIRI <https://w3id.org/jochumsson/h2hoa/1.0.0> ;
  dcterms:issued "2026-01-29"^^xsd:date ;
  dcterms:modified "2026-01-29"^^xsd:date .

#################################################################
# H2HOA - start of the ontology marker
# For automatic merging and parsing purposes
#################################################################

#################################################################
#
# This file contains application-level causal and manifestation rules
# for hydrogen hazard analysis. These rules are NOT part of
# the conceptual H2HO ontology described in the paper "A Hazard
# Ontology Based on IEC 61508", but are added at a later stage during
# application ontology development and knowledge base construction,
# as discussed in the paper: "An Ontological Approach for Hazard 
# Analysis Representation Aligned with IEC61508: A Hydrogen System 
# Case Study".
#
# These rules belong to the application layer: scenario modelling,
# causal sequence construction, and hazard analysis.
#
# They illustrate how HO61508 object properties (resultsIn,
# enables, manifestsIn) may be used to represent domain hazard
# analysis.
#
# The conceptual ontology (h2ho.ttl) intentionally excludes such
# rules to remain general, reusable, and structurally aligned
# with IEC 61508 at an abstract level.
#
# This file is organised into the following sections:
# A: Hazard application extensions
# B: HazardSource application role specifications
# C: Endurant extensions that carry HazardSource as a role
# D: HazardousEvent application extensions
# E: HazardousSituation application extensions
# F: Exposed application role specifications
# G: HarmfulEvent application extensions
# H: Harm application extension
# I: Hazard inheresIn HazardSource application restrictions
# J: Endurant carries HazardSource application restrictions
# K: HazardousEvent triggers Hazard application restrictions
# L: HazardousEvent resultsIn HazardousSituation application restrictions
# M: HazardousSituation enables HazardousEvent application restrictions
# N: HazardousSituation involves Hazard application restrictions
# P: HazardousSituation exposes Exposed application restrictions
# Q: Hazard manifestsIn HarmfulEvent application restrictions
# R: HarmfulEvent leadsTo HazardousSituation application restrictions
# S: HarmfulEvent causes Harm application restrictions
#################################################################

#################################################################
# A: ho61508:Hazard application extensions
# Application layer specialisation of the ho61508:Hazard entity
#################################################################

### H2HOA hazard family disjunction
[] a owl:AllDisjointClasses ;
   owl:members (
     h2ho:FlammabilityHazard
     h2ho:ToxicityHazard
     h2ho:OxygenDeficiencyHazard
     h2ho:PressureHazard
     h2ho:ThermalHazard
     h2ho:ElectricalPowerHazard
   ) .

h2hoa:JetFireHazard a owl:Class ;
  rdfs:subClassOf h2ho:FlammabilityHazard ;
  rdfs:comment "Hazard whose manifestation is a jet fire." .

h2hoa:FireballHazard a owl:Class ;
  rdfs:subClassOf h2ho:FlammabilityHazard ;
  rdfs:comment "Hazard whose manifestation is a fireball." .

h2hoa:PoolFireHazard a owl:Class ;
  rdfs:subClassOf h2ho:FlammabilityHazard ;
  rdfs:comment "Hazard whose manifestation is a pool fire." .

h2hoa:DeflagrationHazard a owl:Class ;
  rdfs:subClassOf h2ho:FlammabilityHazard ;
  rdfs:comment "Hazard whose manifestation is a deflagration (slow or fast)." .

h2hoa:DetonationHazard a owl:Class ;
  rdfs:subClassOf h2ho:FlammabilityHazard ;
  rdfs:comment "Hazard whose manifestation is a detonation." .

### H2HOA flammability hazard family disjunction
[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:JetFireHazard
     h2hoa:FireballHazard
     h2hoa:PoolFireHazard
     h2hoa:DeflagrationHazard
     h2hoa:DetonationHazard
   ) .

#################################################################
# B: HazardSource application role specifications
# Application layer role specialisation of the ho61508:HazardSource entity
#################################################################

[] a owl:AllDisjointClasses ;
   owl:members (
     h2ho:StorageVesselHazardSource
     h2ho:PipingHazardSource
     h2ho:ProcessEquipmentHazardSource
     h2ho:EnvironmentalConfinementHazardSource
   ) .



#################################################################
# C: Contextual endurant extensions that carry HazardSource as a role
#
#################################################################

h2hoa:composes a owl:ObjectProperty ;
  owl:inverseOf h2hoa:composedOf ;
  rdfs:domain h2hoa:HazardContext ;
  rdfs:range h2hoa:HazardContext ;
  rdfs:comment "Inverse of composedOf." .

h2hoa:PhysicalLocation a owl:Class ;
  rdfs:subClassOf gufo:SpaceRegion ;
  rdfs:comment "Physical location or facility region that structurally anchors a hazard context." .

h2hoa:HazardContext a owl:Class ;
  rdfs:subClassOf gufo:Endurant ;
  rdfs:comment "Structural abstraction for contextual entity types whose instances represent hazard context grounded in real-world entities." .

h2hoa:composedOf a owl:ObjectProperty ;
  rdfs:domain h2hoa:HazardContext ;
  rdfs:range h2hoa:HazardContext ;
  rdfs:comment "Relates a hazard context to contextual elements that form part of it." .

h2hoa:locatedIn a owl:ObjectProperty ;
  rdfs:domain h2hoa:HazardContext ;
  rdfs:range h2hoa:PhysicalLocation ;
  rdfs:comment "Relates a hazard context to the physical location in which it is situated." .

h2hoa:hasLocatedContext a owl:ObjectProperty ;
  owl:inverseOf h2hoa:locatedIn ;
  rdfs:domain h2hoa:PhysicalLocation ;
  rdfs:range h2hoa:HazardContext ;
  rdfs:comment "Inverse of locatedIn." .

h2hoa:HazardContext
  rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty h2hoa:locatedIn ;
      owl:someValuesFrom h2hoa:PhysicalLocation ;
      rdfs:comment "Every HazardContext is anchored in at least one PhysicalLocation."
    ] .

h2hoa:HazardSourceContext a owl:Class ;
  rdfs:subClassOf h2hoa:HazardContext ;
  rdfs:comment "Contextual entity type whose instances ground the ho61508:HazardSource role." .

h2hoa:carries a owl:ObjectProperty ;
  owl:inverseOf ho61508:carriedBy ;
  rdfs:domain h2hoa:HazardSourceContext ;
  rdfs:range ho61508:HazardSource ;
  rdfs:comment "Relates a hazard-source context to the HazardSource role it carries." .

h2hoa:StorageVessel a owl:Class ;
  rdfs:subClassOf h2hoa:HazardSourceContext ;
  rdfs:comment "Component or system whose main function is to store hydrogen or related media (gas or liquid)." .

h2hoa:LH2Storage a owl:Class ;
  rdfs:subClassOf h2hoa:StorageVessel ;
  rdfs:comment "Cryogenic tank or containment system storing liquid hydrogen (LH2)." .

h2hoa:HighPressureH2Storage a owl:Class ;
  rdfs:subClassOf h2hoa:StorageVessel ;
  rdfs:comment "Storage vessel containing hydrogen at elevated pressure." .

h2hoa:Piping a owl:Class ;
  rdfs:subClassOf h2hoa:HazardSourceContext ;
  rdfs:comment "Piping or pipework used to transport hydrogen between system components." .

h2hoa:ProcessEquipment a owl:Class ;
  rdfs:subClassOf h2hoa:HazardSourceContext ;
  rdfs:comment "Equipment that processes, conditions, or uses hydrogen (for example, compressors, valves, reformers, and fuel cells)." .

h2hoa:Valve a owl:Class ;
  rdfs:subClassOf h2hoa:ProcessEquipment ;
  rdfs:comment "A flow-control component within hydrogen systems. Valves may jam or malfunction under cryogenic conditions, enabling LossOfFunction events such as ValveJam." .

h2hoa:Electrolyser a owl:Class ;
  rdfs:subClassOf h2hoa:ProcessEquipment ;
  rdfs:comment "Equipment that produces hydrogen through electrolysis. It can carry the ho61508:HazardSource role when participating in accident scenarios." .

h2hoa:FuelCell a owl:Class ;
  rdfs:subClassOf h2hoa:ProcessEquipment ;
  rdfs:comment "Equipment that converts hydrogen into electricity. It can carry the ho61508:HazardSource role when participating in accident scenarios." .

h2hoa:BatteryStorage a owl:Class ;
  rdfs:subClassOf h2hoa:ProcessEquipment ;
  rdfs:comment "Battery energy storage system (BESS), including cells, modules, BMS, and enclosure." .

h2hoa:Inverter a owl:Class ;
  rdfs:subClassOf h2hoa:ProcessEquipment ;
  rdfs:comment "Inverter unit." .

h2hoa:EnvironmentalConfinement a owl:Class ;
  rdfs:subClassOf h2hoa:HazardSourceContext ;
  rdfs:comment "Structures or surroundings that confine hydrogen or combustion products, such as buildings, enclosures, or congested layouts." .

#################################################################
# D: HazardousEvent application extensions
# Application layer ho61508:HazardousEvent specialisation
#################################################################

[] a owl:AllDisjointClasses ;
   owl:members (
     h2ho:Ignition
     h2ho:ExternalEvent
     h2ho:Malfunction
     h2ho:LossOfFunction
     h2ho:HumanError
   ) .

h2hoa:LossOfContainment a owl:Class ;
  rdfs:subClassOf h2ho:LossOfFunction ;
  rdfs:comment "Loss of physical containment of hydrogen. A specialisation of LossOfFunction." .

h2hoa:HydrogenRelease a owl:Class ;
  rdfs:subClassOf h2hoa:LossOfContainment ;
  rdfs:comment "Uncontrolled hydrogen release following containment failure." .

h2hoa:PipePlug a owl:Class ;
  rdfs:subClassOf h2ho:LossOfFunction ;
  rdfs:comment "A LossOfFunction event in which pipes or orifices become blocked due to the solidification of atmospheric gases (e.g., air or nitrogen) when exposed to liquid hydrogen temperatures. This blockage may enable or contribute to a subsequent LossOfContainment event." .

h2hoa:ValveJam a owl:Class ;
  rdfs:subClassOf h2ho:LossOfFunction ;
  rdfs:comment "A LossOfFunction event in which a valve becomes stuck or jammed due to cryogenic freezing of atmospheric gases or condensate. The loss of valve operability may enable or contribute to a subsequent LossOfContainment event." .

h2hoa:AirLeakage a owl:Class ;
  rdfs:subClassOf h2ho:LossOfFunction ;
  rdfs:comment "LossOfFunction event in which air, nitrogen, or other ambient gases leak into liquid hydrogen equipment, enabling freezing, oxygen enrichment, cryopumping, and subsequent degradation." .

h2hoa:Cryopumping a owl:Class ;
  rdfs:subClassOf h2ho:LossOfFunction ;
  rdfs:comment "LossOfFunction event in which condensation of ambient gases at cryogenic temperatures reduces gas volume and creates a vacuum that draws in additional air or gas. Cryopumping may contribute to blockages, cryogenic material degradation, or subsequent overpressure." .

[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:PipePlug
     h2hoa:ValveJam
     h2hoa:AirLeakage
     h2hoa:Cryopumping
   ) .

h2hoa:HighPressureRelease a owl:Class ;
  rdfs:subClassOf h2hoa:HydrogenRelease ;
  rdfs:comment "Hydrogen release from a high-pressure vessel or piping." .

h2hoa:Rupture a owl:Class ;
  rdfs:subClassOf h2hoa:HighPressureRelease ;
  rdfs:comment "Sudden or catastrophic failure of containment (rupture), typically initiating a rapid hydrogen release." .

h2hoa:LowPressureRelease a owl:Class ;
  rdfs:subClassOf h2hoa:HydrogenRelease ;
  rdfs:comment "Hydrogen release from a low-pressure source." .

h2hoa:LH2Release a owl:Class ;
  rdfs:subClassOf h2hoa:HydrogenRelease ;
  rdfs:comment "Release of liquid hydrogen (LH2), potentially forming cryogenic and flammable hazards." .

[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:HighPressureRelease
     h2hoa:LowPressureRelease
     h2hoa:LH2Release
   ) .

h2hoa:FlameIgnition a owl:Class ;
  rdfs:subClassOf h2ho:Ignition ;
  rdfs:comment "Ignition caused by an open flame (e.g., burner flame, torch, flare, or welding flame)." .

h2hoa:HotSurfaceIgnition a owl:Class ;
  rdfs:subClassOf h2ho:Ignition ;
  rdfs:comment "Ignition caused by a sufficiently hot surface in contact with a hydrogen–air mixture." .

h2hoa:FrictionIgnition a owl:Class ;
  rdfs:subClassOf h2ho:Ignition ;
  rdfs:comment "Ignition caused by frictional heating between components (bearings, misaligned parts, or worn equipment)." .

h2hoa:StaticSparkIgnition a owl:Class ;
  rdfs:subClassOf h2ho:Ignition ;
  rdfs:comment "Ignition caused by electrostatic discharge (ESD), even below the human perception threshold." .

h2hoa:AutoIgnition a owl:Class ;
  rdfs:subClassOf h2ho:Ignition ;
  rdfs:comment "Ignition without an external ignition source, where the thermal energy of the hydrogen molecules is the source of ignition." .

h2hoa:EscalationIgnition a owl:Class ;
  rdfs:subClassOf h2ho:Ignition ;
  rdfs:comment "An ignition event representing escalation within a causal flammability hazard chain, typically driven by a prior ignition, where no distinct intermediate ignition event occurs beyond the ongoing combustion itself." .

[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:FlameIgnition
     h2hoa:HotSurfaceIgnition
     h2hoa:FrictionIgnition
     h2hoa:StaticSparkIgnition
     h2hoa:AutoIgnition
     h2hoa:EscalationIgnition
   ) .

h2hoa:HighEnergyIgnition a owl:Class ;
  rdfs:subClassOf h2ho:Ignition .

h2hoa:ElectricalFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Electrical malfunction affecting power supply, insulation, grounding, wiring, or control electronics." .

h2hoa:InstrumentationFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure of sensing, measurement, or signal transmission (e.g., sensor drift, loss of signal, or incorrect readings)." .

h2hoa:ControlSystemFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure of logic, software, control loops, or interlocks (e.g., incorrect control action or PLC fault)." .

h2hoa:ValveFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure of a valve to operate as intended (stuck open or closed, leaking, wrong position, or actuator fault)." .

h2hoa:ReliefSystemFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure of a pressure relief or venting function (blocked relief, undersized relief, or a stuck relief valve)." .

h2hoa:ContainmentIntegrityFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure of barriers that provide containment integrity short of a full rupture (seal failure, flange leak, or gasket failure)." .

h2hoa:CryogenicInsulationFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure of insulation, vacuum, or jacket systems leading to abnormal heat ingress or cold exposure in cryogenic equipment." .

h2hoa:VentilationFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure or loss of ventilation or dilution systems that normally prevent hazardous atmospheres." .

h2hoa:DetectionFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure of gas or flame detection, alarm, or safety monitoring to detect hazardous states." .

h2hoa:HumanMachineInterfaceFailure a owl:Class ;
  rdfs:subClassOf h2ho:Malfunction ;
  rdfs:comment "Failure of the operator interface, misleading indications, or incorrect configuration that contributes to incorrect actions." .

[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:ElectricalFailure
     h2hoa:InstrumentationFailure
     h2hoa:ControlSystemFailure
     h2hoa:ValveFailure
     h2hoa:ReliefSystemFailure
     h2hoa:ContainmentIntegrityFailure
     h2hoa:CryogenicInsulationFailure
     h2hoa:VentilationFailure
     h2hoa:DetectionFailure
     h2hoa:HumanMachineInterfaceFailure
   ) .

h2hoa:ComposedHazardousEvent a owl:Class ;
  rdfs:subClassOf ho61508:HazardousEvent ;
  rdfs:comment """
Application-level HazardousEvent that is modelled as composed of multiple HazardousEvent components for hazard analysis purposes.
Supports entirely disjoint hazardous event types, where composition provides a means to represent events at a higher level of abstraction.
""" .

h2hoa:composedOfEvent a owl:ObjectProperty ;
  rdfs:domain h2hoa:ComposedHazardousEvent ;
  rdfs:range  ho61508:HazardousEvent ;
  rdfs:comment "Relates a composed hazardous event to its component hazardous events (analysis-level decomposition)." .

h2hoa:composesEvent a owl:ObjectProperty ;
  owl:inverseOf h2hoa:composedOfEvent ;
  rdfs:domain ho61508:HazardousEvent ;
  rdfs:range  h2hoa:ComposedHazardousEvent ;
  rdfs:comment "Inverse of composedOfEvent, useful for querying which composed events a component participates in." .

h2hoa:ComposedHazardousEvent rdfs:subClassOf
  [ a owl:Restriction ;
    owl:onProperty h2hoa:composedOfEvent ;
    owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
    owl:onClass ho61508:HazardousEvent ;
    rdfs:comment "A composed hazardous event is composed of at least two events."
  ] .

#################################################################
# E: HazardousSituation application extensions
# Application layer ho61508:HazardousSituation specification
#################################################################

h2hoa:HydrogenJet a owl:Class ;
  rdfs:subClassOf h2ho:FlammableCondition ;
  rdfs:comment "HazardousSituation in which hydrogen emerges as a momentum-driven jet, for example after a pressurised release. Portions of the jet are within flammable limits and can produce a jet fire if ignited." .

h2hoa:FlammableVaporCloud a owl:Class ;
  rdfs:subClassOf h2ho:FlammableCondition ;
  rdfs:comment "HazardousSituation in which a dispersed hydrogen–air cloud is within flammable limits. Relevant for fireball and vapour cloud explosion scenarios." .

h2hoa:CryogenicHydrogenPool a owl:Class ;
  rdfs:subClassOf h2ho:FlammableCondition ;
  rdfs:comment """
HazardousSituation in which liquid hydrogen has accumulated as a cryogenic pool
on a surface following a spill or release.
The pool continuously evaporates, producing a flammable hydrogen–air condition
above the liquid surface.

ISO 15916 context: cryogenic hydrogen pool formation following LH2 release
is a recognised precursor to pool fire, fireball, or vapour cloud explosion,
depending on ignition timing and dispersion.
The situation itself does not imply ignition or combustion.
""" .

h2hoa:DeflagrationCondition a owl:Class ;
  rdfs:subClassOf h2ho:FlammableCondition ;
  rdfs:comment "HazardousSituation in which a hydrogen–air condition can support subsonic flame propagation (deflagration), based on concentration, confinement, and turbulence." .

h2hoa:DetonationCondition a owl:Class ;
  rdfs:subClassOf h2ho:FlammableCondition ;
  rdfs:comment "HazardousSituation in which a hydrogen–air condition can support detonation, for example when mixture composition and confinement exceed detonation limits." .

h2hoa:LiquidHydrogenExposureSituation a owl:Class ;
  rdfs:subClassOf h2ho:ExposureSituation ;
  rdfs:comment "Hazardous situation in which substances or components are directly exposed to liquid hydrogen, enabling freezing, solidification, and subsequent material degradation." .

h2hoa:OxygenEnrichment a owl:Class ;
  rdfs:subClassOf h2ho:Contamination ;
  rdfs:comment "Cryogenic contamination scenario leading to oxygen-enriched liquid air." .

h2hoa:CryogenicMaterialDegradation a owl:Class ;
  rdfs:subClassOf h2ho:MaterialDegradation ;
  rdfs:comment "HazardousSituation in which materials, components, or equipment experience degradation due to cryogenic conditions. Examples include freezing of atmospheric gases (air and nitrogen) into solid deposits, loss of ductility, brittleness, and condensate accumulation. CryogenicMaterialDegradation increases the likelihood of LossOfFunction events such as PipePlug, ValveJam, or Cryopumping, and may ultimately enable LossOfContainment or Rupture during warm-up or pressure rise. This situation corresponds to the mechanisms described in ISO 15916 §6.2.3: solidification of gases, cryopumping vacuum effects, freezing-induced blockages, and oxygen-enriched condensate formation on cold surfaces." .

h2hoa:DamagedEquipmentDegradation a owl:Class ;
  rdfs:subClassOf h2ho:MaterialDegradation ;
  rdfs:comment "HazardousSituation in which equipment is physically degraded or impaired (mechanically, thermally, electrically, or cryogenically), reducing functional integrity and potentially enabling LossOfFunction or LossOfContainment events." .

h2hoa:ComposedHazardousSituation a owl:Class ;
  rdfs:subClassOf ho61508:HazardousSituation ;
  rdfs:comment """
Application-layer construct representing a hazardous situation that is analysed
as being composed of multiple hazardous situations.

The composition is analytical and used for hazard analysis purposes.
It does not imply physical part–whole relations, temporal ordering, or
that the constituent situations are mutually exclusive.
""" .

h2hoa:composedOfSituation a owl:ObjectProperty ;
  rdfs:domain h2hoa:ComposedHazardousSituation ;
  rdfs:range  ho61508:HazardousSituation ;
  rdfs:comment """
Relates a composed hazardous situation to the hazardous situations
that constitute it in hazard analysis.
""" .

h2hoa:composesSituation a owl:ObjectProperty ;
  owl:inverseOf h2hoa:composedOfSituation ;
  rdfs:domain ho61508:HazardousSituation ;
  rdfs:range  h2hoa:ComposedHazardousSituation ;
  rdfs:comment """
Indicates that a hazardous situation is a constituent
of a composed hazardous situation.
""" .

h2hoa:ComposedHazardousSituation rdfs:subClassOf
  [ a owl:Restriction ;
    owl:onProperty h2hoa:composedOfSituation ;
    owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
    owl:onClass ho61508:HazardousSituation ;
    rdfs:comment "A composed hazardous situation is composed of at least two situations."
  ] .

#################################################################
# F: Exposed application role specifications
# Application layer definitions and restrictions on exposed 
# context
#################################################################

[] a owl:AllDisjointClasses ;
  owl:members (
    h2ho:ExposedEnvironment
    h2ho:ExposedProperty
    h2ho:ExposedPerson
  ) .

h2hoa:ExposedContext a owl:Class ;
  rdfs:subClassOf h2hoa:HazardContext ;
  rdfs:comment "Contextual entity type whose instances ground the ho61508:Exposed role." .

h2hoa:affectedBy a owl:ObjectProperty ;
  owl:inverseOf ho61508:affects ;
  rdfs:domain h2hoa:ExposedContext ;
  rdfs:range ho61508:Exposed ;
  rdfs:comment "Relates an ExposedContext to the Exposed role that affects it." .

h2hoa:Property a owl:Class ;
  rdfs:subClassOf h2hoa:ExposedContext ;
  rdfs:comment "Application-level contextual representation of exposed property." .

h2hoa:Person a owl:Class ;
  rdfs:subClassOf h2hoa:ExposedContext ;
  rdfs:comment "Application-level contextual representation of exposed persons." .

h2hoa:Environment a owl:Class ;
  rdfs:subClassOf h2hoa:ExposedContext ;
  rdfs:comment "Application-level contextual representation of the exposed environment." .

#################################################################
# G: HarmfulEvent application extensions
# Application layer ho61508:HarmfulEvent specialisations
#################################################################

# HarmfulEvent subtype family disjunction
[] a owl:AllDisjointClasses ;
   owl:members (
     h2ho:PressureWave
     h2ho:Combustion
     h2ho:ElectricalShock
     h2ho:ExposureEvent
   ) .

h2hoa:Fire a owl:Class ;
  rdfs:subClassOf h2ho:Combustion ;
  rdfs:comment "Non-premixed combustion in which hydrogen burns immediately at the release point. Includes jet fires, pool fires, and fireballs." .

h2hoa:JetFire a owl:Class ;
  rdfs:subClassOf h2hoa:Fire ;
  rdfs:comment "Directional flame caused by ignition of a high-velocity hydrogen jet." .

h2hoa:PoolFire a owl:Class ;
  rdfs:subClassOf h2hoa:Fire ;
  rdfs:comment "Fire burning on a released pool of liquid hydrogen." .

h2hoa:Fireball a owl:Class ;
  rdfs:subClassOf h2hoa:Fire ;
  rdfs:comment "Spherical flame cloud resulting from delayed ignition of a dispersed hydrogen–air mixture." .

# Fire disjunction
[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:JetFire
     h2hoa:PoolFire
     h2hoa:Fireball
   ) .

h2hoa:Explosion a owl:Class ;
  rdfs:subClassOf h2ho:Combustion ;
  rdfs:comment "Premixed combustion event occurring within a hydrogen–air mixture. Includes deflagrations and detonations." .

h2hoa:Deflagration a owl:Class ;
  rdfs:subClassOf h2hoa:Explosion ;
  rdfs:comment "Subsonic premixed combustion wave in hydrogen–air mixtures." .

h2hoa:SlowDeflagration a owl:Class ;
  rdfs:subClassOf h2hoa:Deflagration ;
  rdfs:comment "Deflagration with limited flame acceleration." .

h2hoa:FastDeflagration a owl:Class ;
  rdfs:subClassOf h2hoa:Deflagration ;
  rdfs:comment "Accelerated deflagration that may transition to detonation (DDT)." .

# Disjunction between fast and slow deflagration
[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:SlowDeflagration
     h2hoa:FastDeflagration
   ) .

h2hoa:Detonation a owl:Class ;
  rdfs:subClassOf h2hoa:Explosion ;
  rdfs:comment "Supersonic premixed combustion characterised by a shock-induced explosion wave." .

[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:Deflagration
     h2hoa:Detonation
   ) .

h2hoa:ThermalExposureEvent a owl:Class ;
  rdfs:subClassOf h2ho:ExposureEvent ;
  rdfs:comment "A harmful exposure event in which a person or object is subjected to thermal extremes, including heat or cryogenic cold. Represents the abstract manifestation of thermal hazard." .

h2hoa:ToxicExposureEvent a owl:Class ;
  rdfs:subClassOf h2ho:ExposureEvent ;
  rdfs:comment "Exposure to a toxic substance that produces harm." .

h2hoa:HighPressureExposureEvent a owl:Class ;
  rdfs:subClassOf h2ho:ExposureEvent ;
  rdfs:comment "A harmful event in which a person or object is exposed to damaging levels of pressure or blast loading, resulting in injury or structural harm." .

h2hoa:OxygenDeficiencyExposureEvent a owl:Class ;
  rdfs:subClassOf h2ho:ExposureEvent ;
  rdfs:comment "A harmful exposure event in which a person is subjected to an atmosphere with insufficient oxygen, potentially leading to asphyxiation." .

h2hoa:ElectricalCurrentExposureEvent a owl:Class ;
  rdfs:subClassOf h2ho:ExposureEvent ;
  rdfs:comment "A harmful electrical current exposure event." .

# ExposureEvent disjunction
[] a owl:AllDisjointClasses ;
   owl:members (
     h2hoa:ThermalExposureEvent
     h2hoa:ToxicExposureEvent
     h2hoa:HighPressureExposureEvent
     h2hoa:OxygenDeficiencyExposureEvent
     h2hoa:ElectricalCurrentExposureEvent
   ) .

#################################################################
# H: Harm application extension
# Application layer ho61508:Harm specialisations
#################################################################

### Generic damage
h2hoa:Damage a owl:Class ;
  rdfs:subClassOf ho61508:Harm ;
  rdfs:comment "Harm to physical property, equipment, or the environment." .

### Property damage
h2hoa:PropertyDamage a owl:Class ;
  rdfs:subClassOf h2hoa:Damage ;
  rdfs:comment "Damage to buildings or infrastructure." .

### Environmental damage
h2hoa:EnvironmentalDamage a owl:Class ;
  rdfs:subClassOf h2hoa:Damage ;
  rdfs:comment "Damage to the natural environment." .

### Cryogenic cold injury
h2hoa:CryoBurn a owl:Class ;
  rdfs:subClassOf h2ho:Injury ;
  rdfs:comment "Cold injury caused by cryogenic exposure (LH2 or cold gas)." .

### Asphyxiation (non-fatal oxygen deprivation)
h2hoa:Asphyxiation a owl:Class ;
  rdfs:subClassOf h2ho:Injury ;
  rdfs:comment "Harm caused by insufficient oxygen concentration." .

### Heat or flame burn injury
h2hoa:BurnInjury a owl:Class ;
  rdfs:subClassOf h2ho:Injury ;
  rdfs:comment "Non-fatal thermal injury resulting from exposure to flames or hot surfaces." .

### Blast trauma
h2hoa:BlastTrauma a owl:Class ;
  rdfs:subClassOf h2ho:Injury ;
  rdfs:comment "Non-fatal injury caused by a pressure wave or explosion shock load." .

### Toxic injury
h2hoa:ToxicInjury a owl:Class ;
  rdfs:subClassOf h2ho:Injury ;
  rdfs:comment "Non-fatal harm due to toxic substance exposure." .

#################################################################
# I: Hazard inheresIn HazardSource application restrictions
# Application restrictions for which ho61508:Hazard inheres in
# which ho61508:HazardSource
#################################################################

### FlammabilityHazard inheres in a flammability source
h2hoa:FlammabilityHazardSource
  a owl:Class ;
  rdfs:subClassOf ho61508:HazardSource ;
  rdfs:comment """
Named set of HazardSource roles that are permitted bearers of a FlammabilityHazard.
This class exists to make the allowed flammability hazard bearers explicit and queryable.
""" ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:StorageVesselHazardSource
      h2ho:PipingHazardSource
      h2ho:ProcessEquipmentHazardSource
      h2ho:EnvironmentalConfinementHazardSource
    )
  ] .

h2ho:FlammabilityHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
DL: FlammabilityHazard ⊑ ∃ ho61508:inheresIn.FlammabilityHazardSource
Every FlammabilityHazard inheres in at least one permitted flammability hazard source.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:someValuesFrom h2hoa:FlammabilityHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
DL: FlammabilityHazard ⊑ ∀ ho61508:inheresIn.FlammabilityHazardSource
A FlammabilityHazard may inhere only in flammability hazard sources.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:allValuesFrom h2hoa:FlammabilityHazardSource
    ] .

### OxygenDeficiencyHazard inheres in confined environments
h2ho:OxygenDeficiencyHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
DL: OxygenDeficiencyHazard ⊑ ∃ ho61508:inheresIn.EnvironmentalConfinementHazardSource
Every OxygenDeficiencyHazard inheres in at least one environmental confinement.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:someValuesFrom h2ho:EnvironmentalConfinementHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
DL: OxygenDeficiencyHazard ⊑ ∀ ho61508:inheresIn.EnvironmentalConfinementHazardSource
An OxygenDeficiencyHazard may inhere only in environmental confinements.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:allValuesFrom h2ho:EnvironmentalConfinementHazardSource
    ] .

### ThermalHazard inheres in equipment or storage
h2hoa:ThermalHazardSource
  a owl:Class ;
  rdfs:subClassOf ho61508:HazardSource ;
  rdfs:comment """
Named set of HazardSource roles that are permitted bearers of a ThermalHazard.
This class exists to make the allowed thermal hazard bearers explicit, reusable, and testable.
""" ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:StorageVesselHazardSource
      h2ho:PipingHazardSource
      h2ho:ProcessEquipmentHazardSource
    )
  ] .

h2ho:ThermalHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
DL:
ThermalHazard ⊑ ∃ ho61508:inheresIn.StorageVesselHazardSource
Every ThermalHazard inheres in at least one equipment- or storage-related hazard source.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:someValuesFrom h2hoa:ThermalHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
DL:
ThermalHazard ⊑ ∀ ho61508:inheresIn.StorageVesselHazardSource
A ThermalHazard may inhere only in equipment, piping, or storage hazard sources.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:allValuesFrom h2hoa:ThermalHazardSource
    ] .

### PressureHazard inheres in pressurised hardware
h2hoa:PressureHazardSource
  a owl:Class ;
  rdfs:subClassOf ho61508:HazardSource ;
  rdfs:comment """
Named set of HazardSource roles that are permitted bearers of a PressureHazard.
This class exists to make the allowed bearers explicit, reusable, and testable.
""" ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:StorageVesselHazardSource
      h2ho:PipingHazardSource
      h2ho:ProcessEquipmentHazardSource
    )
  ] .

h2ho:PressureHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
DL:
PressureHazard ⊑ ∃ ho61508:inheresIn.PressureHazardSource
Every PressureHazard inheres in at least one pressurised hardware hazard source.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:someValuesFrom h2hoa:PressureHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
DL:
PressureHazard ⊑ ∀ ho61508:inheresIn.PressureHazardSource
A PressureHazard may inhere only in pressurised hardware hazard sources.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:allValuesFrom h2hoa:PressureHazardSource
    ] .

### ElectricalPowerHazard inheres in process equipment
h2ho:ElectricalPowerHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
DL:
ElectricalPowerHazard ⊑ ∃ ho61508:inheresIn.ProcessEquipmentHazardSource
Every ElectricalPowerHazard inheres in at least one process equipment hazard source.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:someValuesFrom h2ho:ProcessEquipmentHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
DL:
ElectricalPowerHazard ⊑ ∀ ho61508:inheresIn.ProcessEquipmentHazardSource
An ElectricalPowerHazard may inhere only in process equipment hazard sources.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:allValuesFrom h2ho:ProcessEquipmentHazardSource
    ] .

### ToxicityHazard inheres in storage, process equipment, or confined volumes
h2hoa:ToxicityHazardSource
  a owl:Class ;
  rdfs:subClassOf ho61508:HazardSource ;
  rdfs:comment "HazardSource roles that may bear a ToxicityHazard." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:StorageVesselHazardSource
      h2ho:PipingHazardSource
      h2ho:ProcessEquipmentHazardSource
      h2ho:EnvironmentalConfinementHazardSource
    )
  ] .

h2ho:ToxicityHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
DL:
ToxicityHazard ⊑ ∃ ho61508:inheresIn.StorageVesselHazardSource
Every ToxicityHazard inheres in at least one hydrogen system hazard source.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:someValuesFrom h2hoa:ToxicityHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
DL:
ToxicityHazard ⊑ ∀ ho61508:inheresIn.StorageVesselHazardSource
A ToxicityHazard may inhere only in the listed hazard source types.
""" ;
      owl:onProperty ho61508:inheresIn ;
      owl:allValuesFrom h2hoa:ToxicityHazardSource
    ] .

#################################################################
# J: Endurant carries HazardSource application restrictions
# Application layer specification of which gufo:Endurant carries
# ho61508:HazardSources
#################################################################

### StorageVessel endurants carry only StorageVesselHazardSource roles
h2hoa:StorageVessel
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
Every StorageVessel carries at least one StorageVesselHazardSource role.
DL: StorageVessel ⊑ ∃ carries.StorageVesselHazardSource
""" ;
      owl:onProperty h2hoa:carries ;
      owl:someValuesFrom h2ho:StorageVesselHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
A StorageVessel may carry only StorageVesselHazardSource roles.
DL: StorageVessel ⊑ ∀ carries.StorageVesselHazardSource
""" ;
      owl:onProperty h2hoa:carries ;
      owl:allValuesFrom h2ho:StorageVesselHazardSource
    ] .

### Piping endurants carry only PipingHazardSource roles
h2hoa:Piping
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
Piping endurants carry at least one PipingHazardSource role.
DL: Piping ⊑ ∃ carries.PipingHazardSource
""" ;
      owl:onProperty h2hoa:carries ;
      owl:someValuesFrom h2ho:PipingHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
Piping endurants may carry only PipingHazardSource roles.
DL: Piping ⊑ ∀ carries.PipingHazardSource
""" ;
      owl:onProperty h2hoa:carries ;
      owl:allValuesFrom h2ho:PipingHazardSource
    ] .

### ProcessEquipment endurants carry only ProcessEquipmentHazardSource roles
h2hoa:ProcessEquipment
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
ProcessEquipment endurants carry at least one ProcessEquipmentHazardSource role.
DL: ProcessEquipment ⊑ ∃ carries.ProcessEquipmentHazardSource
""" ;
      owl:onProperty h2hoa:carries ;
      owl:someValuesFrom h2ho:ProcessEquipmentHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
ProcessEquipment endurants may carry only ProcessEquipmentHazardSource roles.
DL: ProcessEquipment ⊑ ∀ carries.ProcessEquipmentHazardSource
""" ;
      owl:onProperty h2hoa:carries ;
      owl:allValuesFrom h2ho:ProcessEquipmentHazardSource
    ] .

### EnvironmentalConfinement endurants carry only EnvironmentalConfinementHazardSource roles
h2hoa:EnvironmentalConfinement
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
EnvironmentalConfinement endurants carry at least one EnvironmentalConfinementHazardSource role.
DL: EnvironmentalConfinement ⊑ ∃ carries.EnvironmentalConfinementHazardSource
""" ;
      owl:onProperty h2hoa:carries ;
      owl:someValuesFrom h2ho:EnvironmentalConfinementHazardSource
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
EnvironmentalConfinement endurants may carry only EnvironmentalConfinementHazardSource roles.
DL: EnvironmentalConfinement ⊑ ∀ carries.EnvironmentalConfinementHazardSource
""" ;
      owl:onProperty h2hoa:carries ;
      owl:allValuesFrom h2ho:EnvironmentalConfinementHazardSource
    ] .

#################################################################
# K: HazardousEvent triggers Hazard application restrictions
# Application layer restrictions: which ho61508:HazardousEvent
# triggers which ho61508:Hazards
#################################################################

h2hoa:triggeredBy a owl:ObjectProperty ;
  owl:inverseOf ho61508:triggers ;
  rdfs:domain ho61508:Hazard ;
  rdfs:range  ho61508:HazardousEvent ;
  rdfs:comment "Application-layer convenience inverse of ho61508:triggers for hazard-centric querying once event instances exist." .

h2ho:FlammabilityHazard
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty h2hoa:triggeredBy ;
    owl:allValuesFrom h2ho:Ignition ;
    rdfs:comment "DL: FlammabilityHazard ⊑ ∀ triggeredBy.Ignition"
  ] .

h2hoa:ElectricalFailure
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: ElectricalFailure ⊑ ∀ ho61508:triggers.ElectricalPowerHazard
If an electrical failure triggers a hazard, that hazard is an ElectricalPowerHazard.
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2ho:ElectricalPowerHazard
  ] .

h2hoa:VentilationFailure
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: VentilationFailure ⊑ ∀ ho61508:triggers.OxygenDeficiencyHazard
If ventilation fails and a hazard is triggered, it is related to hydrogen accumulation and oxygen displacement.
VentilationFailure does not directly trigger FlammabilityHazard, but it can be an important event in the hazard causal chain.
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2ho:OxygenDeficiencyHazard
  ] .

h2hoa:CryogenicInsulationFailureTrigger a owl:Class ;
  rdfs:comment "Allowed hazard types that CryogenicInsulationFailure may trigger." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:ThermalHazard
      h2ho:PressureHazard
    )
  ] .

h2hoa:CryogenicInsulationFailure
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: CryogenicInsulationFailure ⊑ ∀ ho61508:triggers.(ThermalHazard ⊔ PressureHazard)
If cryogenic insulation or vacuum fails and a hazard is triggered, it is typically thermal (cold exposure or abnormal temperatures) and or pressure-related (boil-off).
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2hoa:CryogenicInsulationFailureTrigger
  ] .

h2hoa:ReliefSystemFailure
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: ReliefSystemFailure ⊑ ∀ ho61508:triggers.PressureHazard
If a relief or venting function fails and it triggers a hazard, it is a PressureHazard.
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2ho:PressureHazard
  ] .

h2hoa:ContainmentIntegrityFailureTrigger a owl:Class ;
  rdfs:comment "Allowed hazard types that ContainmentIntegrityFailure may trigger." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:OxygenDeficiencyHazard
      h2ho:PressureHazard
      h2ho:ToxicityHazard
    )
  ] .

h2hoa:ContainmentIntegrityFailure
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: ContainmentIntegrityFailure ⊑ ∀ ho61508:triggers.(OxygenDeficiencyHazard ⊔ PressureHazard ⊔ ToxicityHazard)
If containment integrity fails and a hazard is triggered, it falls within hazard families relevant to releases and secondary effects.
ContainmentIntegrityFailure does not directly trigger FlammabilityHazard, but it can be an important event in the hazard causal chain.
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2hoa:ContainmentIntegrityFailureTrigger
  ] .

h2hoa:ValveFailureTrigger a owl:Class ;
  rdfs:comment "Allowed hazard types that ValveFailure may trigger." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:PressureHazard
      h2ho:OxygenDeficiencyHazard
    )
  ] .

h2hoa:ValveFailure
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: ValveFailure ⊑ ∀ ho61508:triggers.(PressureHazard ⊔ OxygenDeficiencyHazard)
Valve malfunction can cause overpressure or flow deviations and may contribute to releases leading to flammability or oxygen displacement hazards.
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2hoa:ValveFailureTrigger
  ] .

h2hoa:ControlSystemFailureTrigger a owl:Class ;
  rdfs:comment "Allowed hazard types that ControlSystemFailure may trigger." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:ToxicityHazard
      h2ho:OxygenDeficiencyHazard
      h2ho:ElectricalPowerHazard
      h2ho:PressureHazard
      h2ho:ThermalHazard
    )
  ] .

h2hoa:ControlSystemFailure
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: HumanMachineInterfaceFailure ⊑ ∀ ho61508:triggers.(ToxicityHazard ⊔ OxygenDeficiencyHazard ⊔ ElectricalPowerHazard ⊔ PressureHazard ⊔ ThermalHazard)
Control system malfunction can cause overpressure or flow deviations and may contribute to releases leading to flammability or oxygen displacement hazards.
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2hoa:ControlSystemFailureTrigger
  ] .

h2hoa:InstrumentationFailureTrigger a owl:Class ;
  rdfs:comment "Allowed hazard types that InstrumentationFailure may trigger." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:ToxicityHazard
      h2ho:OxygenDeficiencyHazard
      h2ho:ElectricalPowerHazard
      h2ho:PressureHazard
      h2ho:ThermalHazard
    )
  ] .

h2hoa:InstrumentationFailure
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: HumanMachineInterfaceFailure ⊑ ∀ ho61508:triggers.(ToxicityHazard ⊔ OxygenDeficiencyHazard ⊔ ElectricalPowerHazard ⊔ PressureHazard ⊔ ThermalHazard)
Instrumentation malfunction can cause overpressure or flow deviations and may contribute to releases leading to flammability or oxygen displacement hazards.
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2hoa:InstrumentationFailureTrigger
  ] .

h2hoa:LossOfFunctionTrigger a owl:Class ;
  rdfs:comment "Allowed hazard types that LossOfFunction may trigger." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:ToxicityHazard
      h2ho:OxygenDeficiencyHazard
      h2ho:PressureHazard
      h2ho:ThermalHazard
    )
  ] .

h2ho:LossOfFunction
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: LossOfFunction ⊑ ∀ ho61508:triggers.(ToxicityHazard ⊔ OxygenDeficiencyHazard ⊔ PressureHazard ⊔ ThermalHazard)
Loss of function and containment can cause overpressure or flow deviations and may contribute to hydrogen releases leading to flammability or oxygen displacement hazards.
""" ;
    owl:onProperty ho61508:triggers ;
    owl:allValuesFrom h2hoa:LossOfFunctionTrigger
  ] .

h2hoa:DetonationHazard
  rdfs:subClassOf [
    a owl:Restriction ;
    rdfs:comment """
DL: DetonationHazard ⊑ ∀ ho61508:triggeredBy.HighEnergyIgnition
If a detonation hazard is triggered, it is by a high-energy ignition event.
""" ;
    owl:onProperty h2hoa:triggeredBy ;
    owl:allValuesFrom h2hoa:HighEnergyIgnition
  ] .

##################################################################
# L: HazardousEvent resultsIn HazardousSituation application restrictions
# Application layer restriction: which ho61508:HazardousEvent
# resultsIn which ho61508:HazardousSituations
##################################################################

h2hoa:HydrogenRelease
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty ho61508:resultsIn ;
      owl:someValuesFrom h2ho:FlammableCondition ;
      rdfs:comment "A HydrogenRelease produces at least one flammable hydrogen air condition through dispersion and mixing."
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty ho61508:resultsIn ;
      owl:allValuesFrom h2ho:FlammableCondition ;
      rdfs:comment "If a HydrogenRelease resultsIn a HazardousSituation, that situation must be a FlammableCondition."
    ] .

h2hoa:ExternalEventResultInSituation
  a owl:Class ;
  rdfs:comment "Allowed HazardousSituation types that may be the outcome of an ExternalEvent." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2hoa:DamagedEquipmentDegradation
      h2ho:ExposureSituation
    )
  ] .

h2ho:ExternalEvent
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:resultsIn ;
    owl:allValuesFrom h2hoa:ExternalEventResultInSituation ;
    rdfs:comment "If an ExternalEvent resultsIn a HazardousSituation, that situation must be included in the ExternalEventResultInSituation union."
  ] .

h2hoa:MalfunctionResultInSituation
  a owl:Class ;
  rdfs:comment "Allowed HazardousSituation types that may be the outcome of a Malfunction." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:Contamination
      h2ho:ExposureSituation
      h2ho:Overpressure
    )
  ] .

h2ho:Malfunction
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:resultsIn ;
    owl:allValuesFrom h2hoa:MalfunctionResultInSituation ;
    rdfs:comment "If a Malfunction resultsIn a HazardousSituation, that situation must be in the MalfunctionResultInSituation union."
  ] .

h2hoa:LossOfFunctionResultInSituation
  a owl:Class ;
  rdfs:comment "Allowed HazardousSituation types that may be the outcome of a LossOfFunction." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:Contamination
      h2ho:ExposureSituation
      h2ho:Overpressure
      h2hoa:DamagedEquipmentDegradation
    )
  ] .

h2ho:LossOfFunction
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:resultsIn ;
    owl:allValuesFrom h2hoa:LossOfFunctionResultInSituation ;
    rdfs:comment "If a LossOfFunction resultsIn a HazardousSituation, that situation must be defined in the LossOfFunctionResultInSituation union."
  ] .

##################################################################
# M: HazardousSituation enables HazardousEvent application restrictions
# Application layer restrictions: which ho61508:HazardousSituation
# enable which ho61508:HazardousEvent
##################################################################

h2ho:FlammableCondition
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty ho61508:enables ;
      owl:allValuesFrom h2ho:Ignition ;
      rdfs:comment
        "If a FlammableCondition enables a HazardousEvent, that event must be an Ignition."
    ] .

h2hoa:MaterialDegradationEnablesEvent
  a owl:Class ;
  rdfs:comment "Allowed HazardousEvent types that MaterialDegradation may enable." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2hoa:Ignition
      h2hoa:HydrogenRelease
      h2ho:LossOfFunction
      h2ho:Malfunction
    )
  ] .

h2ho:MaterialDegradation
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:enables ;
    owl:allValuesFrom h2hoa:MaterialDegradationEnablesEvent ;
    rdfs:comment
      "If MaterialDegradation enables a HazardousEvent, that event must be part of the event union defined by MaterialDegradationEnablesEvent"
  ] .

h2hoa:OverpressureEnablesEvent
  a owl:Class ;
  rdfs:comment "Allowed HazardousEvent types that may be enabled by Overpressure." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2hoa:ContainmentIntegrityFailure
      h2hoa:ReliefSystemFailure
      h2hoa:ValveFailure
    )
  ] .

h2ho:Overpressure
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:enables ;
    owl:allValuesFrom h2hoa:OverpressureEnablesEvent ;
    rdfs:comment "If Overpressure enables a HazardousEvent, that event must be a containment integrity failure, relief system failure, or valve failure."
  ] .

h2hoa:ContaminationEnablesEvent
  a owl:Class ;
  rdfs:comment "Allowed HazardousEvent types for ho61508:enables from Contamination." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:Malfunction
      h2ho:LossOfFunction
    )
  ] .

h2ho:Contamination
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:enables ;
    owl:allValuesFrom h2hoa:ContaminationEnablesEvent
  ] .



##################################################################
# N: HazardousSituation involves Hazard application restrictions
# ##################################################################

ho61508:HazardousSituation
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:involves ;
    owl:someValuesFrom ho61508:Hazard ;
    rdfs:comment """
IEC 61508 aligned: every HazardousSituation involves at least one Hazard.
Open world assumption applies: this does not force which hazard, only that one exists.
""" ;
  ] .

h2ho:FlammableCondition
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
IEC 61508 aligned: a HazardousSituation involves the hazard(s) present in that situation.
A FlammableCondition represents the existence of a flammable hydrogen–air mixture,
as used in ISO 15916-style hazard analysis (flammable atmospheres leading to fire or explosion scenarios).
Therefore, every FlammableCondition involves at least one FlammabilityHazard.
""" ;
      owl:onProperty ho61508:involves ;
      owl:someValuesFrom h2ho:FlammabilityHazard
    ] .

h2hoa:HydrogenJet
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:someValuesFrom h2hoa:JetFireHazard ;
      rdfs:comment "A HydrogenJet involves at least one JetFireHazard." ;
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:allValuesFrom h2hoa:JetFireHazard ;
      rdfs:comment "A HydrogenJet involves only JetFireHazard." ;
    ] .

h2hoa:FlammableVaporCloud
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:someValuesFrom h2hoa:FireballHazard ;
      rdfs:comment "A FlammableVaporCloud involves at least one FireballHazard." ;
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:allValuesFrom h2hoa:FireballHazard ;
      rdfs:comment "A FlammableVaporCloud involves only FireballHazard." ;
    ] .


h2hoa:CryogenicHydrogenPool
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:someValuesFrom h2hoa:PoolFireHazard ;
      rdfs:comment "A CryogenicHydrogenPool involves at least one PoolFireHazard." ;
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:allValuesFrom h2hoa:PoolFireHazard ;
      rdfs:comment "A CryogenicHydrogenPool involves only PoolFireHazard." ;
    ] .

h2hoa:DeflagrationCondition
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:someValuesFrom h2hoa:DeflagrationHazard ;
      rdfs:comment "A DeflagrationCondition involves at least one DeflagrationHazard." ;
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:allValuesFrom h2hoa:DeflagrationHazard ;
      rdfs:comment "A DeflagrationCondition involves only DeflagrationHazard." ;
    ] .

h2hoa:DetonationCondition
  rdfs:subClassOf
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:someValuesFrom h2hoa:DetonationHazard ;
      rdfs:comment "A DetonationCondition involves at least one DetonationHazard." ;
    ] ,
    [
      a owl:Restriction ;
      owl:onProperty ho61508:involves ;
      owl:allValuesFrom h2hoa:DetonationHazard ;
      rdfs:comment "A DetonationCondition involves only DetonationHazard." ;
    ] .


##################################################################
# P: HazardousSituation exposes Exposed application restrictions
##################################################################

h2hoa:Person
  rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty h2hoa:affectedBy ;
      owl:allValuesFrom h2ho:ExposedPerson ;
      rdfs:comment "A Person may be affected only by ExposedPerson roles."
    ] .

h2hoa:Property
  rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty h2hoa:affectedBy ;
      owl:allValuesFrom h2ho:ExposedProperty ;
      rdfs:comment "A Property may be affected only by ExposedProperty roles."
    ] .

h2hoa:Environment
  rdfs:subClassOf
    [ a owl:Restriction ;
      owl:onProperty h2hoa:affectedBy ;
      owl:allValuesFrom h2ho:ExposedEnvironment ;
      rdfs:comment "An Environment may be affected only by ExposedEnvironment roles."
    ] .

#################################################################
# Q: Hazard manifestsIn HarmfulEvent application restrictions
# Application layer restrictions: which ho61508:Hazard
# manifestsIn which ho61508:HarmfulEvents
#################################################################

h2ho:FlammabilityHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment """
A FlammabilityHazard manifests in at least one Combustion harmful event.
This is a type fence at the abstraction level: it does not enumerate leaf event types.
Extension occurs by adding new subclasses of h2ho:Combustion (or reusing existing ones),
not by modifying this restriction.
""" ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2ho:Combustion
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment """
If a FlammabilityHazard manifestsIn any HarmfulEvent, it must be a Combustion.
This closes the abstraction-level range without enumerating specific combustion subtypes.
""" ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2ho:Combustion
    ] .

h2hoa:JetFireHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "A JetFireHazard manifests in at least one JetFire." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:JetFire
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "A JetFireHazard manifests only in JetFire." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:JetFire
    ] .

h2hoa:FireballHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "A FireballHazard manifests in at least one Fireball." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:Fireball
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "A FireballHazard manifests only in Fireball." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:Fireball
    ] .

h2hoa:PoolFireHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "A PoolFireHazard manifests in at least one PoolFire." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:PoolFire
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "A PoolFireHazard manifests only in PoolFire." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:PoolFire
    ] .

h2hoa:DeflagrationHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "A DeflagrationHazard manifests in at least one Deflagration." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:Deflagration
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "A DeflagrationHazard manifests only in Deflagration." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:Deflagration
    ] .

h2hoa:DetonationHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "A DetonationHazard manifests in at least one Detonation." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:Detonation
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "A DetonationHazard manifests only in Detonation." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:Detonation
    ] .

h2ho:PressureHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "A PressureHazard manifests as a harmful high-pressure exposure event affecting persons or structures." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:HighPressureExposureEvent
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "If a PressureHazard manifestsIn a harmful event, it must be a HighPressureExposureEvent." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:HighPressureExposureEvent
    ] .

h2ho:OxygenDeficiencyHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "An OxygenDeficiencyHazard manifests as an exposure event in which persons are subjected to a low-oxygen atmosphere." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:OxygenDeficiencyExposureEvent
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "If an OxygenDeficiencyHazard manifestsIn a harmful event, it must be an OxygenDeficiencyExposureEvent." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:OxygenDeficiencyExposureEvent
    ] .

h2ho:ToxicityHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "A ToxicityHazard manifests as a harmful exposure event involving toxic or harmful substances." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:ToxicExposureEvent
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "If a ToxicityHazard manifestsIn a harmful event, it must be a ToxicExposureEvent." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:ToxicExposureEvent
    ] .

h2ho:ElectricalPowerHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "An ElectricalPowerHazard manifests as an electrical shock harmful event." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2ho:ElectricalShock
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "If an ElectricalPowerHazard manifestsIn a harmful event, it must be an ElectricalShock." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2ho:ElectricalShock
    ] .

h2ho:ThermalHazard
  rdfs:subClassOf
    [
      a owl:Restriction ;
      rdfs:comment "A ThermalHazard manifests as a thermal exposure harmful event, representing injury or damage due to hot or cryogenic thermal conditions." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:someValuesFrom h2hoa:ThermalExposureEvent
    ] ,
    [
      a owl:Restriction ;
      rdfs:comment "If a ThermalHazard manifestsIn a harmful event, it must be a ThermalExposureEvent." ;
      owl:onProperty ho61508:manifestsIn ;
      owl:allValuesFrom h2hoa:ThermalExposureEvent
    ] .

#################################################################
# R: HarmfulEvent leadsTo HazardousSituation application restrictions
# Application layer restrictions: which ho61508:HarmfulEvent ho61508:leadsTo
# which ho61508:HazardousSituation
#################################################################

ho61508:HarmfulEvent
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:leadsTo ;
    owl:allValuesFrom ho61508:HazardousSituation ;
    rdfs:comment "Application fence: leadsTo from a HarmfulEvent points only to HazardousSituations." ;
  ] .

h2hoa:CombustionLeadsToSituation
  a owl:Class ;
  rdfs:comment "Allowed HazardousSituation types that may follow a Combustion harmful event." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:FlammableCondition
      h2ho:ExposureSituation
      h2hoa:DamagedEquipmentDegradation
    )
  ] .

h2ho:Combustion
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:leadsTo ;
    owl:allValuesFrom h2hoa:CombustionLeadsToSituation ;
    rdfs:comment "If a Combustion leadsTo a HazardousSituation, it must be one of the allowed situation types." ;
  ] .

#################################################################
# S: HarmfulEvent causes Harm application restrictions
#################################################################

h2hoa:PressureWaveCausesHarm
  a owl:Class ;
  rdfs:comment "Allowed harm outcomes for PressureWave." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2hoa:Damage
      h2ho:Injury
      h2ho:Death
    )
  ] .

h2ho:PressureWave
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:causes ;
    owl:allValuesFrom h2hoa:PressureWaveCausesHarm ;
    rdfs:comment "If a PressureWave causes harm, that harm must be part of the PressureWaveCausesHarm union."
  ] .

h2hoa:CombustionCausesHarm
  a owl:Class ;
  rdfs:comment "Allowed harm outcomes for Combustion." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2hoa:Damage
      h2ho:Injury
      h2ho:Death
    )
  ] .

h2ho:Combustion
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:causes ;
    owl:allValuesFrom h2hoa:CombustionCausesHarm ;
    rdfs:comment "If a Combustion causes harm, that harm must be part of the CombustionCausesHarm union."
  ] .


h2hoa:ElectricalShockCausesHarm
  a owl:Class ;
  rdfs:comment "Allowed harm outcomes for ElectricalShock." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2ho:Injury
      h2ho:Death
    )
  ] .

h2ho:ElectricalShock
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:causes ;
    owl:allValuesFrom h2hoa:ElectricalShockCausesHarm ;
    rdfs:comment "If an ElectricalShock causes harm, that harm must be part of the ElectricalShockCausesHarm union."
  ] .

h2hoa:ExposureEventCausesHarm
  a owl:Class ;
  rdfs:comment "Allowed harm outcomes for ExposureEvent." ;
  owl:equivalentClass [
    a owl:Class ;
    owl:unionOf (
      h2hoa:Damage
      h2ho:Injury
      h2ho:Death
    )
  ] .

h2ho:ExposureEvent
  rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty ho61508:causes ;
    owl:allValuesFrom h2hoa:ExposureEventCausesHarm ;
    rdfs:comment "If an ExposureEvent causes harm, that harm must be part of the ExposureEventCausesHarm union."
  ] .
