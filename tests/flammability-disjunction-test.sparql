PREFIX h2ho:    <https://w3id.org/jochumsson/h2ho#>
PREFIX h2hoa:   <https://w3id.org/jochumsson/h2ho-a#>
PREFIX ho61508: <https://w3id.org/jochumsson/ho61508#>
PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT ( "Test disjoint declaration of flammability hazard specialisations." AS ?violation )
WHERE {
  FILTER NOT EXISTS {
    ?adc a owl:AllDisjointClasses ;
         owl:members ?list .

    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:JetFireHazard . }
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:FireballHazard . }
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:PoolFireHazard . }
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:DeflagrationHazard . }
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:DetonationHazard . }
  }
}
