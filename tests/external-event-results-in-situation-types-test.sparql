PREFIX h2ho:    <https://w3id.org/jochumsson/h2ho#>
PREFIX h2hoa:   <https://w3id.org/jochumsson/h2ho-a#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>

SELECT ( "ExternalEventResultInSituation union is incomplete: must contain DamagedEquipmentDegradation and ExposureSituation." AS ?violation )
WHERE {
  FILTER NOT EXISTS {
    h2hoa:ExternalEventResultInSituation owl:equivalentClass ?ec .
    ?ec owl:unionOf ?list .
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:DamagedEquipmentDegradation }
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2ho:ExposureSituation }
  }
}
