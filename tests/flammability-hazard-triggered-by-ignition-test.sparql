############################################################
# Rule:
# FlammabilityHazard ⊑ ∃ ho61508:triggeredBy.Ignition
#                    ⊓ ∀ ho61508:triggeredBy.Ignition
#
# Violation:
# FlammabilityHazard is triggered by something other
# than Ignition, or the universal restriction is
# removed or weakened.
############################################################

# PARAMETERS:
#   ?HazardClass:     h2ho:FlammabilityHazard
#   ?Property:        ho61508:triggeredBy
#   ?AllowedTrigger:  h2ho:Ignition

PREFIX h2ho: <https://w3id.org/jochumsson/h2ho#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ho61508: <https://w3id.org/jochumsson/ho61508#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT ?violation
WHERE {
  {
    SELECT
      (COUNT(DISTINCT ?someR) AS ?someCnt)
      (COUNT(DISTINCT ?allR)  AS ?allCnt)
    WHERE {
      VALUES (?HazardClass ?Property ?AllowedTrigger) {
        (h2ho:FlammabilityHazard ho61508:triggeredBy h2ho:Ignition)
      }

      OPTIONAL {
        ?HazardClass rdfs:subClassOf ?someR .
        ?someR a owl:Restriction ;
               owl:onProperty ?Property ;
               owl:someValuesFrom ?AllowedTrigger .
      }

      OPTIONAL {
        ?HazardClass rdfs:subClassOf ?allR .
        ?allR a owl:Restriction ;
              owl:onProperty ?Property ;
              owl:allValuesFrom ?AllowedTrigger .
      }
    }
  }

  FILTER (?someCnt != 1 || ?allCnt != 1)

  BIND(
    CONCAT(
      "Expected exactly 1 SOME and 1 ALL triggeredBy restriction for FlammabilityHazard but found SOME=",
      STR(?someCnt), ", ALL=", STR(?allCnt)
    ) AS ?violation
  )
}

