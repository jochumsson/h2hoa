PREFIX h2hoa:    <https://w3id.org/jochumsson/h2ho-a#>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT ( "Test disjoint declaration of exposure event subtypes." AS ?violation )
WHERE {
  FILTER NOT EXISTS {
    ?adc a owl:AllDisjointClasses ; owl:members ?list .
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:ThermalExposureEvent . }
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:ToxicExposureEvent . }
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:HighPressureExposureEvent . }
    FILTER EXISTS { ?list rdf:rest*/rdf:first h2hoa:OxygenDeficiencyExposureEvent . }
  }
}
