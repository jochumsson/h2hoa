PREFIX h2ho:    <https://w3id.org/jochumsson/h2ho#>
PREFIX h2hoa:   <https://w3id.org/jochumsson/h2ho-a#>
PREFIX ho61508: <https://w3id.org/jochumsson/ho61508#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>

SELECT ?hazard
WHERE {
  ?hazard rdfs:subClassOf h2hoa:ElectricalPowerHazard .

  FILTER NOT EXISTS {
    ?hazard rdfs:subClassOf [
      a owl:Restriction ;
      owl:onProperty ho61508:inheresIn ;
      owl:someValuesFrom h2hoa:ProcessEquipmentHazardSource
    ]
  }
}
