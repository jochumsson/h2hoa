############################################################
# Rule:
# DetonationHazard ⊑ ∃ ho61508:triggeredBy.FlameAcceleration
#
# Violation:
# DetonationHazard lacks an existential triggeredBy
# restriction to FlameAcceleration.
############################################################

# PARAMETERS:
#   ?HazardClass:     h2ho:DetonationHazard
#   ?Property:        ho61508:triggeredBy
#   ?AllowedTrigger:  h2ho:FlameAcceleration

PREFIX h2ho: <https://w3id.org/jochumsson/h2ho#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ho61508: <https://w3id.org/jochumsson/ho61508#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT ?violation
WHERE {
  {
    SELECT (COUNT(DISTINCT ?someR) AS ?someCnt)
    WHERE {
      VALUES (?HazardClass ?Property ?AllowedTrigger) {
        (h2ho:DetonationHazard ho61508:triggeredBy h2ho:FlameAcceleration)
      }

      OPTIONAL {
        ?HazardClass rdfs:subClassOf ?someR .
        ?someR a owl:Restriction ;
               owl:onProperty ?Property ;
               owl:someValuesFrom ?AllowedTrigger .
      }
    }
  }

  FILTER (?someCnt != 1)

  BIND(
    CONCAT(
      "Expected DetonationHazard to have SOME triggeredBy FlameAcceleration restriction, but found ",
      STR(?someCnt)
    ) AS ?violation
  )
}

