PREFIX h2hoa:   <https://w3id.org/jochumsson/h2ho-a#>
PREFIX h2ho:    <https://w3id.org/jochumsson/h2ho#>
PREFIX ho61508: <https://w3id.org/jochumsson/ho61508#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>

SELECT ( "h2hoa:FlammableCondition missing: involves some h2ho:FlammabilityHazard" AS ?violation )
WHERE {
  FILTER NOT EXISTS {
    h2hoa:FlammableCondition rdfs:subClassOf ?r .
    ?r a owl:Restriction ;
       owl:onProperty ho61508:involves ;
       owl:someValuesFrom h2ho:FlammabilityHazard .
  }
}
