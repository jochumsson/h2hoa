PREFIX h2hoa:    <https://w3id.org/jochumsson/h2ho-a#>
PREFIX h2ho:     <https://w3id.org/jochumsson/h2ho#>
PREFIX ho61508:  <https://w3id.org/jochumsson/ho61508#>
PREFIX rdfs:     <http://www.w3.org/2000/01/rdf-schema#>
PREFIX owl:      <http://www.w3.org/2002/07/owl#>
PREFIX rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

SELECT (CONCAT(
  "h2ho:Combustion ho61508:leadsTo union helper missing or incomplete. Expected member not found: ",
  STR(?ExpectedMember)
) AS ?violation)
WHERE {
  VALUES (?EventClass ?Property ?Helper) {
    (h2ho:Combustion ho61508:leadsTo h2hoa:CombustionLeadsToSituation)
  }

  VALUES ?ExpectedMember {
    h2hoa:FlammableCondition
    h2ho:ExposureSituation
    h2hoa:DamagedEquipmentDegradation
  }

  FILTER NOT EXISTS {
    ?EventClass rdfs:subClassOf ?r .
    ?r a owl:Restriction ;
       owl:onProperty ?Property ;
       owl:allValuesFrom ?Helper .

    ?Helper owl:equivalentClass ?ec .
    ?ec owl:unionOf ?list .
    ?list rdf:rest*/rdf:first ?ExpectedMember .
  }
}
