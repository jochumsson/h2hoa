############################################################
# Rule:
# ToxicityHazard ⊑ ∃ ho61508:triggeredBy.ToxicityHazardTrigger
#              ⊓ ∀ ho61508:triggeredBy.ToxicityHazardTrigger
#
# Where:
# ToxicityHazardTrigger ≡ ExternalEvent ⊔ Malfunction ⊔ LossOfFunction
#
# Violation:
# ToxicityHazard is triggered by events outside the allowed trigger set,
# or the existential/universal trigger restriction is removed or weakened.
############################################################

# PARAMETERS:
#   ?HazardClass:       h2ho:ToxicityHazard
#   ?Property:          ho61508:triggeredBy
#   ?AllowedTrigger:    h2ho:ToxicityHazardTrigger

PREFIX h2ho: <https://w3id.org/jochumsson/h2ho#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX ho61508: <https://w3id.org/jochumsson/ho61508#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>

SELECT ?violation
WHERE {
  {
    SELECT
      (COUNT(DISTINCT ?someR) AS ?someCnt)
      (COUNT(DISTINCT ?allR)  AS ?allCnt)
    WHERE {
      VALUES (?HazardClass ?Property ?AllowedTrigger) {
        (h2ho:ToxicityHazard ho61508:triggeredBy h2ho:ToxicityHazardTrigger)
      }

      OPTIONAL {
        ?HazardClass rdfs:subClassOf ?someR .
        ?someR a owl:Restriction ;
               owl:onProperty ?Property ;
               owl:someValuesFrom ?AllowedTrigger .
      }

      OPTIONAL {
        ?HazardClass rdfs:subClassOf ?allR .
        ?allR a owl:Restriction ;
              owl:onProperty ?Property ;
              owl:allValuesFrom ?AllowedTrigger .
      }
    }
  }

  FILTER (?someCnt != 1 || ?allCnt != 1)

  BIND(
    CONCAT(
      "Expected exactly 1 SOME and 1 ALL triggeredBy restriction for ",
      STR(h2ho:ToxicityHazard),
      " but found SOME=", STR(?someCnt), ", ALL=", STR(?allCnt)
    ) AS ?violation
  )
}

